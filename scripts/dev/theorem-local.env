# Theorem local-dev environment for the harness MCP server + satellites.
#
# Source this from a runner script (see run-harness.sh / run-grpc.sh).
# These servers read PROCESS env (no dotenv autoload), so it must be exported
# into the launching shell, not just written to a file.
#
# Layout of dependencies (who reaches what):
#   harness MCP server (rustyred-thg-server) -> embeddings, search, browser, gRPC
#   theorem-grpc (code search)               -> Valkey      <-- Valkey lives HERE
#
# Fill the PLACEHOLDER_* values, or comment out a block to leave that surface off
# (every surface degrades gracefully when unset).

# Resolve the repo root relative to this file so data paths are absolute.
THEOREM_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../.." && pwd)"

# ---------------------------------------------------------------------------
# Core harness server (rustyred-thg-server) -- all local, no external dep
# ---------------------------------------------------------------------------
export RUSTY_RED_HOST="127.0.0.1"
export RUSTY_RED_PORT="8380"
export RUSTY_RED_MODE="embedded"                      # native RedCore on local disk
export RUSTY_RED_DATA_DIR="${THEOREM_REPO_ROOT}/.local-data/rusty-red"
export RUSTY_RED_REQUIRE_AUTH="false"                 # local dev: skip bearer tokens
export RUSTY_RED_MCP_DEFAULT_TENANT="default"

# ---------------------------------------------------------------------------
# 1) gRPC code search  (harness dials theorem-grpc; run run-grpc.sh too)
# ---------------------------------------------------------------------------
# Unset -> compute_code returns a clean "not configured" error. Set -> dials it.
export THEOREM_GRPC_URL="http://127.0.0.1:50071"

# ---------------------------------------------------------------------------
# 2) Embeddings  (Qwen3-Embedding-4B contract, dim 2560)
# ---------------------------------------------------------------------------
# Endpoint shape is auto-detected: a URL containing "/embeddings" is treated as
# OpenAI-compatible ({model,input} -> data[].embedding); anything else as
# HuggingFace TEI ({model,inputs} -> embeddings[]). The docker-compose TEI
# service serves the OpenAI route at :8081/v1/embeddings with bge-small (384-dim).
export RUSTYWEB_QWEN4B_EMBED_URL="http://127.0.0.1:8081/v1/embeddings"
# Dimension MUST match the served model so vector designations line up. The
# compose default (bge-small-en-v1.5) is 384; the real Qwen3-Embedding-4B is 2560.
export RUSTYWEB_QWEN4B_DIMENSION="384"
# export RUSTYWEB_QWEN4B_MODEL_ID="BAAI/bge-small-en-v1.5"

# ---------------------------------------------------------------------------
# 3) Search providers  (comma list; each needs its own key/URL)
# ---------------------------------------------------------------------------
# SearXNG is the only fully-local, no-API-key option. Add cloud providers by
# extending the list and supplying their keys.
export RUSTYWEB_SEARCH_PROVIDERS="searxng"
export SEARXNG_URL="http://127.0.0.1:8888"
# export RUSTYWEB_SEARCH_PROVIDERS="searxng,brave,exa"
# export BRAVE_SEARCH_API_KEY="PLACEHOLDER_BRAVE_KEY"
# export EXA_API_KEY="PLACEHOLDER_EXA_KEY"
# export PERPLEXITY_API_KEY="PLACEHOLDER_PPLX_KEY"
# export FIRECRAWL_API_KEY="PLACEHOLDER_FIRECRAWL_KEY"
# Fully-offline alternative (no network): a JSONL seed manifest.
# export RUSTYWEB_SEARCH_PROVIDERS="offline"
# export RUSTYWEB_OFFLINE_SEARCH_MANIFEST="${THEOREM_REPO_ROOT}/.local-data/search-seed.jsonl"

# ---------------------------------------------------------------------------
# 4) Browser -- TWO distinct surfaces (see README)
# ---------------------------------------------------------------------------
# Both surfaces are served by the one browser-sidecar (docker-compose service
# browser-sidecar, or scripts/dev/browser-sidecar run locally) on :9223.
#
# 4a) Rendered-fetch escalation: the fetch cascade upgrades JS-heavy pages to a
#     rendered DOM. Read-only. Unset -> cascade does plain HTTP fetch.
export THEOREM_SERVO_RENDER_ENDPOINT="http://127.0.0.1:9223/render"
#
# 4b) Live action loop: drives browse_with_me / browse_for_me actuation (click,
#     type, navigate) via sessions/checkout|snapshot|actuate. Unset -> those
#     tools fall back to the cascade. POOL_SIZE bounds concurrent sessions.
export THEOREM_LIVE_BROWSER_ENDPOINT="http://127.0.0.1:9223"
export THEOREM_LIVE_BROWSER_POOL_SIZE="4"
#
# 4c) Visual fallback perceiver: OmniParser-style screenshot parser for pages or
#     app surfaces with no DOM/a11y interactive elements. Run with:
#     uvicorn perception_visual.serve.app:app --port 8080
export THEOREM_VISUAL_PERCEIVER_URL="http://127.0.0.1:8080"
