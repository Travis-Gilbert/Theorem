#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly DEFAULT_SOURCE_DIR="$HOME/.theorem/source"
readonly THEOREM_HOME_DIR="${THEOREM_HOME:-$HOME/.theorem}"
readonly PID_FILE="$THEOREM_HOME_DIR/localmodel.pid"
readonly NODE_PID_FILE="$THEOREM_HOME_DIR/node.pid"
readonly PROXY_PID_FILE="$THEOREM_HOME_DIR/proxy.pid"
readonly OUT_LOG="$THEOREM_HOME_DIR/localmodel.out.log"
readonly ERR_LOG="$THEOREM_HOME_DIR/localmodel.err.log"
readonly NODE_OUT_LOG="$THEOREM_HOME_DIR/node.out.log"
readonly NODE_ERR_LOG="$THEOREM_HOME_DIR/node.err.log"
readonly PROXY_OUT_LOG="$THEOREM_HOME_DIR/proxy.out.log"
readonly PROXY_ERR_LOG="$THEOREM_HOME_DIR/proxy.err.log"
readonly CONNECT_STATE_DIR="$THEOREM_HOME_DIR/connect"

export MISTRALRS_METAL_PRECOMPILE="${MISTRALRS_METAL_PRECOMPILE:-0}"
export MISTRALRS_METAL_PLATFORMS="${MISTRALRS_METAL_PLATFORMS:-macos}"

usage() {
    cat <<'EOF'
usage: theorem <command> [args]

Commands:
  init [--force] [dir]     Create a no-secret starter config and first-turn note.
  harness [localmodel args...] Start the full local node: proxy plus theorem-localmodel.
  start [localmodel args...]   Start theorem-localmodel in the foreground.
  serve-model [config]     Start the local mistral.rs model host.
  up                       Start local RustyRed node plus model-path proxy.
  proxy [proxy args...]    Start the Anthropic Messages proxy on localhost.
  graph <command> [args...] Query file graph context for Yazi and shell workflows.
  federation <command> [args...]
                           Inspect or run the opt-in Iroh federation lane.
  connect <claude|codex> [--check]
                           Point an agent at the local proxy, reversibly.
  disconnect <claude|codex>
                           Restore config changed by `theorem connect`.
  appear [actor] [opts]    Announce a local actor into the harness room.
  codex-endpoint [args...] Start Codex app-server and announce its endpoint.
  wrap <claude|codex>      Start proxy room wiring, then launch the agent CLI.
  once <prompt>            Run one theorem-localmodel turn and print the transcript.
  stop                     Stop the background localmodel started by install.sh.
  status                   Show background localmodel status and source checkout.
  logs                     Tail background localmodel logs.
  doctor                   Check local prerequisites and repo discovery.
  model-doctor [config]    Print local mistral.rs/Theorem host diagnostics.
  localmodel [args...]     Pass arguments directly to theorem-localmodel.
  agentd [args...]         Compatibility alias for localmodel.
  repo                     Print the source checkout used by this wrapper.
EOF
}

log() {
    printf '[theorem] %s\n' "$*" >&2
}

json_quote() {
    local value=${1-}
    if command -v python3 >/dev/null 2>&1; then
        python3 -c 'import json, sys; print(json.dumps(sys.argv[1]))' "$value"
        return 0
    fi
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    value=${value//$'\t'/\\t}
    printf '"%s"' "$value"
}

find_agentd_bin() {
    if [[ -n "${THEOREM_LOCALMODEL_BIN:-}" && -x "$THEOREM_LOCALMODEL_BIN" ]]; then
        printf '%s\n' "$THEOREM_LOCALMODEL_BIN"
        return 0
    fi

    if [[ -n "${THEOREM_AGENTD_BIN:-}" && -x "$THEOREM_AGENTD_BIN" ]]; then
        printf '%s\n' "$THEOREM_AGENTD_BIN"
        return 0
    fi

    if command -v theorem-localmodel >/dev/null 2>&1; then
        command -v theorem-localmodel
        return 0
    fi

    if command -v theorem-agentd >/dev/null 2>&1; then
        command -v theorem-agentd
        return 0
    fi

    if [[ -x "$SCRIPT_DIR/theorem-localmodel" ]]; then
        printf '%s\n' "$SCRIPT_DIR/theorem-localmodel"
        return 0
    fi

    if [[ -x "$SCRIPT_DIR/theorem-agentd" ]]; then
        printf '%s\n' "$SCRIPT_DIR/theorem-agentd"
        return 0
    fi

    return 1
}

find_proxy_bin() {
    if [[ -n "${THEOREM_PROXY_BIN:-}" && -x "$THEOREM_PROXY_BIN" ]]; then
        printf '%s\n' "$THEOREM_PROXY_BIN"
        return 0
    fi

    if command -v rustyred-proxy >/dev/null 2>&1; then
        command -v rustyred-proxy
        return 0
    fi

    if [[ -x "$SCRIPT_DIR/rustyred-proxy" ]]; then
        printf '%s\n' "$SCRIPT_DIR/rustyred-proxy"
        return 0
    fi

    return 1
}

find_theorem_proxy_bin() {
    if [[ -n "${THEOREM_PROXY_BIN:-}" && -x "$THEOREM_PROXY_BIN" ]]; then
        printf '%s\n' "$THEOREM_PROXY_BIN"
        return 0
    fi

    if command -v theorem-proxy >/dev/null 2>&1; then
        command -v theorem-proxy
        return 0
    fi

    if [[ -x "$HOME/.cargo/bin/theorem-proxy" ]]; then
        printf '%s\n' "$HOME/.cargo/bin/theorem-proxy"
        return 0
    fi

    local repo
    if repo="$(find_repo 2>/dev/null)"; then
        if [[ -x "$repo/apps/theorem-proxy/target/release/theorem-proxy" ]]; then
            printf '%s\n' "$repo/apps/theorem-proxy/target/release/theorem-proxy"
            return 0
        fi
        if [[ -x "$repo/apps/theorem-proxy/target/debug/theorem-proxy" ]]; then
            printf '%s\n' "$repo/apps/theorem-proxy/target/debug/theorem-proxy"
            return 0
        fi
    fi

    return 1
}

find_federation_bin() {
    if [[ -n "${THEOREM_FEDERATION_BIN:-}" && -x "$THEOREM_FEDERATION_BIN" ]]; then
        printf '%s\n' "$THEOREM_FEDERATION_BIN"
        return 0
    fi

    if command -v theorem-federation >/dev/null 2>&1; then
        command -v theorem-federation
        return 0
    fi

    local repo
    if repo="$(find_repo 2>/dev/null)"; then
        if [[ -x "$repo/apps/theorem-federation/target/release/theorem-federation" ]]; then
            printf '%s\n' "$repo/apps/theorem-federation/target/release/theorem-federation"
            return 0
        fi
        if [[ -x "$repo/apps/theorem-federation/target/debug/theorem-federation" ]]; then
            printf '%s\n' "$repo/apps/theorem-federation/target/debug/theorem-federation"
            return 0
        fi
    fi

    return 1
}

find_repo() {
    if [[ -n "${THEOREM_REPO:-}" && -f "$THEOREM_REPO/rustyredcore_THG/Cargo.toml" ]]; then
        printf '%s\n' "$THEOREM_REPO"
        return 0
    fi

    local dir=$PWD
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/rustyredcore_THG/Cargo.toml" ]]; then
            printf '%s\n' "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    local script_repo
    script_repo="$(cd "$SCRIPT_DIR/.." && pwd)"
    if [[ -f "$script_repo/rustyredcore_THG/Cargo.toml" ]]; then
        printf '%s\n' "$script_repo"
        return 0
    fi

    if [[ -f "$DEFAULT_SOURCE_DIR/rustyredcore_THG/Cargo.toml" ]]; then
        printf '%s\n' "$DEFAULT_SOURCE_DIR"
        return 0
    fi

    log "cannot find a Theorem checkout. Set THEOREM_REPO or run scripts/install.sh."
    return 1
}

localmodel_config_arg() {
    if [[ -n "${THEOREM_LOCALMODEL_CONFIG:-}" ]]; then
        printf '%s\n' "$THEOREM_LOCALMODEL_CONFIG"
        return 0
    fi

    if [[ -n "${THEOREM_AGENTD_CONFIG:-}" ]]; then
        printf '%s\n' "$THEOREM_AGENTD_CONFIG"
        return 0
    fi

    if [[ -f "$PWD/theorem-localmodel.toml" ]]; then
        printf '%s\n' "$PWD/theorem-localmodel.toml"
        return 0
    fi

    if [[ -f "$PWD/theorem-agentd.toml" ]]; then
        log "using legacy theorem-agentd.toml; rename it to theorem-localmodel.toml when convenient"
        printf '%s\n' "$PWD/theorem-agentd.toml"
        return 0
    fi

    return 1
}

run_agentd() {
    local agentd_bin
    if agentd_bin="$(find_agentd_bin)"; then
        "$agentd_bin" "$@"
        return
    fi
    local repo
    repo="$(find_repo)"
    cargo run --manifest-path "$repo/rustyredcore_THG/Cargo.toml" -p theorem-localmodel -- "$@"
}

exec_agentd() {
    local agentd_bin
    if agentd_bin="$(find_agentd_bin)"; then
        exec "$agentd_bin" "$@"
    fi
    local repo
    repo="$(find_repo)"
    exec cargo run --manifest-path "$repo/rustyredcore_THG/Cargo.toml" -p theorem-localmodel -- "$@"
}

exec_proxy() {
    local proxy_bin
    if proxy_bin="$(find_proxy_bin)"; then
        exec "$proxy_bin" "$@"
    fi
    local repo
    repo="$(find_repo)"
    exec cargo run --manifest-path "$repo/rustyredcore_THG/Cargo.toml" -p rustyred-proxy --bin rustyred-proxy -- "$@"
}

write_localmodel_config() {
    local file=$1
    local force=$2
    if [[ -f "$file" && "$force" != "true" ]]; then
        log "kept existing $file"
        return 0
    fi

    cat >"$file" <<'EOF'
# Created by `theorem init`.
# Safe first-run config: no bearer token, model API key, or data-dir env var.

default_room_id = "repo:theorem:branch:main"
actor = "theorem-localmodel"
operator_memory_tenant = "Travis-Gilbert"

[model]
provider = "rule"
temperature = 0.2
max_tokens = 1200
request_timeout_secs = 120
grammar_constrained = true

# To use a resident OpenAI-compatible model:
#
# provider = "openai-compatible"
# base_url = "http://127.0.0.1:8080"
# model = "gemma-4-12b-it-qat"
# api_key_env = "THEOREM_MODEL_API_KEY"
#
# Put real secrets in environment variables, never in this file.

[local_model]
host = "127.0.0.1"
port = 8080
api_model_id = "gemma-4-12b-it-qat"
tok_model_id = "google/gemma-4-12B-it"
quantized_model_id = "apps/theorem-localmodel"
quantized_filename = "gemma-4-12B-it-qat-UD-Q4_K_XL.gguf"
quantization = "Q4_K_XL"
token_source = "cache"
paged_attention = true
max_seqs = 16
max_seq_len = 4096
max_batch_size = 1
resident_memory_estimate_gb = 9.0

# Optional speculative decoding for Gemma 4 MTP assistant checkpoints:
#
# [local_model.drafter]
# model = "google/gemma-4-12B-it-mtp"
# n_predict = 4

[harness]
name = "harness"
url = "http://127.0.0.1:8380/mcp"
tenant_slug = "Travis-Gilbert"

# Hosted sync is opt-in. For the hosted Theorem MCP, change url to:
# url = "https://rustyredcore-theorem-production.up.railway.app/mcp"

[receiver]
enabled = false
config_path = "theorem-receiver.toml"

[loop_config]
max_iterations = 8
tick_interval_secs = 60
storm_guard_window_secs = 600

[ledger]
path = ".theorem/localmodel-token-ledger.jsonl"
mirror_to_graph = true

[capture]
enabled = false
repo = "Travis-Gilbert/theorem"
dispatched_subtask_title = "dispatched"

[relay]
enabled = false
EOF
}

write_first_turn_note() {
    local file=$1
    local force=$2
    if [[ -f "$file" && "$force" != "true" ]]; then
        log "kept existing $file"
        return 0
    fi

    cat >"$file" <<'EOF'
# First Theorem turn

Run a no-secret smoke:

```bash
theorem once "hello from Theorem"
```

That prints a JSON transcript and writes `.theorem/localmodel-token-ledger.jsonl`.
When you are ready for live model decisions, edit `theorem-localmodel.toml` and set
`[model].provider = "openai-compatible"` plus your local model endpoint.
EOF
}

cmd_init() {
    local force=false
    local target_dir=.

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)
                force=true
                ;;
            -h | --help)
                printf 'usage: theorem init [--force] [dir]\n'
                return 0
                ;;
            -*)
                log "unknown init flag $1"
                return 1
                ;;
            *)
                target_dir=$1
                ;;
        esac
        shift
    done

    mkdir -p "$target_dir/.theorem/examples"
    write_localmodel_config "$target_dir/theorem-localmodel.toml" "$force"
    write_first_turn_note "$target_dir/.theorem/examples/first-turn.md" "$force"
    log "initialized $target_dir"
    log "next: cd $target_dir && theorem once \"hello from Theorem\""
}

cmd_once() {
    if [[ $# -lt 1 ]]; then
        log "once requires a prompt"
        return 1
    fi
    local prompt=$1
    shift
    local word
    for word in "$@"; do
        prompt+=" $word"
    done
    local config_path
    if config_path="$(localmodel_config_arg)"; then
        run_agentd --once "$prompt" "$config_path"
    else
        run_agentd --once "$prompt"
    fi
}

cmd_start() {
    mkdir -p "$THEOREM_HOME_DIR"
    local config_path
    if [[ $# -eq 0 ]] && config_path="$(localmodel_config_arg)"; then
        exec_agentd "$config_path"
    fi
    exec_agentd "$@"
}

cmd_serve_model() {
    local config_path
    if [[ $# -eq 0 ]] && config_path="$(localmodel_config_arg)"; then
        exec_agentd serve "$config_path"
    fi
    exec_agentd serve "$@"
}

cmd_model_doctor() {
    local config_path
    if [[ $# -eq 0 ]] && config_path="$(localmodel_config_arg)"; then
        run_agentd doctor "$config_path"
        return
    fi
    run_agentd doctor "$@"
}

cmd_proxy() {
    mkdir -p "$THEOREM_HOME_DIR"
    local config_path
    if config_path="$(localmodel_config_arg)"; then
        exec_proxy "$@" "$config_path"
    fi
    exec_proxy "$@"
}

cmd_graph() {
    local proxy_bin
    if proxy_bin="$(find_theorem_proxy_bin)"; then
        exec "$proxy_bin" graph "$@"
    fi
    local repo
    repo="$(find_repo)"
    exec cargo run --manifest-path "$repo/apps/theorem-proxy/Cargo.toml" -- graph "$@"
}

cmd_federation() {
    local federation_bin
    if federation_bin="$(find_federation_bin)"; then
        "$federation_bin" "$@"
        return
    fi
    local repo
    repo="$(find_repo)"
    cargo run --manifest-path "$repo/apps/theorem-federation/Cargo.toml" -- "$@"
}

cmd_harness() {
    local port="${THEOREM_PROXY_PORT:-8484}"
    local data_dir="${THEOREM_PROXY_DATA_DIR:-$THEOREM_HOME_DIR/proxy}"
    local base_url="http://127.0.0.1:$port"
    local proxy_args=(--proxy-port "$port" --proxy-data-dir "$data_dir")
    local config_path=""
    if config_path="$(localmodel_config_arg)"; then
        proxy_args+=("$config_path")
    else
        config_path=""
    fi

    mkdir -p "$THEOREM_HOME_DIR" "$data_dir"
    "$0" proxy "${proxy_args[@]}" &
    local proxy_pid=$!
    trap 'kill "$proxy_pid" 2>/dev/null || true' EXIT INT TERM
    if ! wait_for_proxy "$base_url"; then
        kill "$proxy_pid" 2>/dev/null || true
        log "proxy did not become healthy at $base_url"
        return 1
    fi
    log "proxy ready at $base_url"

    local status=0
    if [[ $# -eq 0 && -n "$config_path" ]]; then
        run_agentd "$config_path" || status=$?
    else
        run_agentd "$@" || status=$?
    fi
    kill "$proxy_pid" 2>/dev/null || true
    trap - EXIT INT TERM
    return "$status"
}

wait_for_proxy() {
    local url=$1
    local attempt
    for attempt in $(seq 1 50); do
        if command -v curl >/dev/null 2>&1 && curl -fsS "$url/healthz" >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.1
    done
    return 1
}

proxy_base_url() {
    local port="${THEOREM_PROXY_PORT:-8788}"
    printf 'http://127.0.0.1:%s\n' "$port"
}

# The legacy proxy (`theorem proxy/harness/wrap`, flag `--proxy-port`) defaults to
# 8484; the new model-path proxy (`theorem up/connect`, flag `--port`) defaults to
# 8788. They are alternatives, never co-resident, and only the legacy proxy serves
# `/v1/presence`. Presence/room callers must reach the legacy port, not proxy_base_url.
legacy_proxy_base_url() {
    local port="${THEOREM_PROXY_PORT:-8484}"
    printf 'http://127.0.0.1:%s\n' "$port"
}

node_base_url() {
    local port="${RUSTY_RED_PORT:-8380}"
    printf 'http://127.0.0.1:%s\n' "$port"
}

proxy_status_json() {
    local base_url
    base_url="$(proxy_base_url)"
    curl -fsS "$base_url/status"
}

json_field() {
    local field=$1
    python3 -c 'import json,sys; data=json.load(sys.stdin); value=data.get(sys.argv[1]); print("" if value is None else value)' "$field"
}

wait_for_http() {
    local url=$1
    local attempt
    for attempt in $(seq 1 300); do
        if command -v curl >/dev/null 2>&1 && curl -fsS "$url" >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.2
    done
    return 1
}

http_ok() {
    command -v curl >/dev/null 2>&1 && curl -fsS "$1" >/dev/null 2>&1
}

start_local_node() {
    local repo
    repo="$(find_repo)"
    local base_url
    base_url="$(node_base_url)"
    if wait_for_http "$base_url/ready"; then
        log "node already ready at $base_url"
        return 0
    fi

    mkdir -p "$THEOREM_HOME_DIR"
    RUSTY_RED_PORT="${RUSTY_RED_PORT:-8380}" \
        bash "$repo/apps/theorem-proxy/scripts/node-local.sh" \
        >"$NODE_OUT_LOG" 2>"$NODE_ERR_LOG" </dev/null &
    local node_pid=$!
    printf '%s\n' "$node_pid" >"$NODE_PID_FILE"
    if ! wait_for_http "$base_url/ready"; then
        kill "$node_pid" 2>/dev/null || true
        log "node did not become ready at $base_url"
        log "logs: $NODE_OUT_LOG $NODE_ERR_LOG"
        return 1
    fi
    log "started node pid $node_pid at $base_url"
}

default_memory_dir_for_repo() {
    local repo=$1
    local project_key legacy_project_key default_mem_dir
    project_key="$(printf '%s' "$repo" | sed 's#/#-#g; s# #-#g')"
    legacy_project_key="$(printf '%s' "$repo" | sed 's#/#-#g')"
    default_mem_dir="$HOME/.claude/projects/$project_key/memory"
    if [[ ! -d "$default_mem_dir" && -d "$HOME/.claude/projects/$legacy_project_key/memory" ]]; then
        default_mem_dir="$HOME/.claude/projects/$legacy_project_key/memory"
    fi
    printf '%s\n' "$default_mem_dir"
}

start_model_path_proxy() {
    local repo
    repo="$(find_repo)"
    local base_url
    base_url="$(proxy_base_url)"
    if wait_for_http "$base_url/healthz"; then
        log "proxy already healthy at $base_url"
        return 0
    fi

    local proxy_bin
    if proxy_bin="$(find_theorem_proxy_bin)"; then
        :
    else
        log "theorem-proxy not found; build it with: cargo install --path \"$repo/apps/theorem-proxy\" --force"
        return 1
    fi

    local node_url memory_dir source_args=()
    node_url="$(node_base_url)/mcp"
    if [[ "${THEOREM_USE_NODE_MEMORY:-1}" != "0" ]]; then
        source_args=(--memory-url "$node_url")
    else
        memory_dir="${THEOREM_MEMORY_DIR:-$(default_memory_dir_for_repo "$repo")}"
        source_args=(--memory-dir "$memory_dir")
    fi

    local port="${THEOREM_PROXY_PORT:-8788}"
    mkdir -p "$THEOREM_HOME_DIR"
    "$proxy_bin" proxy --port "$port" "${source_args[@]}" \
        >"$PROXY_OUT_LOG" 2>"$PROXY_ERR_LOG" </dev/null &
    local proxy_pid=$!
    printf '%s\n' "$proxy_pid" >"$PROXY_PID_FILE"
    if ! wait_for_http "$base_url/healthz"; then
        kill "$proxy_pid" 2>/dev/null || true
        log "proxy did not become healthy at $base_url"
        log "logs: $PROXY_OUT_LOG $PROXY_ERR_LOG"
        return 1
    fi
    log "started proxy pid $proxy_pid at $base_url"
}

cmd_up() {
    start_local_node
    start_model_path_proxy
    if [[ "${THEOREM_PROXY_OPENAI_UPSTREAM:-https://api.openai.com}" == "https://api.openai.com" && -z "${THEOREM_PROXY_OPENAI_UPSTREAM_API_KEY:-}" ]]; then
        log "Codex API/local routing needs THEOREM_PROXY_OPENAI_UPSTREAM_API_KEY, or set THEOREM_PROXY_OPENAI_UPSTREAM to a local OpenAI-compatible host"
    fi
    cmd_status
}

ensure_stack_for_connect() {
    if [[ "${THEOREM_CONNECT_NO_UP:-0}" == "1" ]]; then
        return 0
    fi
    start_local_node
    start_model_path_proxy
}

write_claude_connection() {
    local base_url=$1
    local settings_path="$HOME/.claude/settings.json"
    local desktop_path="$HOME/Library/Application Support/Claude-3p/claude_desktop_config.json"
    local state_path="$CONNECT_STATE_DIR/claude.json"
    mkdir -p "$CONNECT_STATE_DIR"
    python3 - "$settings_path" "$desktop_path" "$state_path" "$base_url" <<'PY'
import json
import shutil
import sys
import time
from pathlib import Path

settings_path = Path(sys.argv[1])
desktop_path = Path(sys.argv[2])
state_path = Path(sys.argv[3])
base_url = sys.argv[4].rstrip("/")
stamp = str(int(time.time()))

def load_json(path):
    if not path.exists():
        return {}
    return json.loads(path.read_text())

def backup(path, label):
    backup_path = state_path.parent / f"{label}.{stamp}.bak"
    if path.exists():
        shutil.copy2(path, backup_path)
        existed = True
    else:
        backup_path.write_text("")
        existed = False
    return {"path": str(path), "backup": str(backup_path), "existed": existed}

state = load_json(state_path) if state_path.exists() else {
    "created_at": stamp,
    "files": {
        "claude_settings": backup(settings_path, "claude-settings"),
        "claude_desktop_3p": backup(desktop_path, "claude-desktop-3p"),
    },
}

settings_path.parent.mkdir(parents=True, exist_ok=True)
settings = load_json(settings_path)
env = settings.setdefault("env", {})
env["ANTHROPIC_BASE_URL"] = base_url
settings_path.write_text(json.dumps(settings, indent=2, sort_keys=False) + "\n")

desktop_path.parent.mkdir(parents=True, exist_ok=True)
desktop = load_json(desktop_path)
desktop["deploymentMode"] = "3p"
enterprise = desktop.setdefault("enterpriseConfig", {})
enterprise["inferenceProvider"] = "gateway"
enterprise["inferenceGatewayBaseUrl"] = base_url
enterprise.setdefault("inferenceGatewayApiKey", "theorem-local-gateway-key")
enterprise["inferenceGatewayAuthScheme"] = "bearer"
enterprise["modelDiscoveryEnabled"] = True
desktop_path.write_text(json.dumps(desktop, indent=2, sort_keys=False) + "\n")

state["base_url"] = base_url
state_path.write_text(json.dumps(state, indent=2, sort_keys=False) + "\n")
PY
    log "Claude Code env written to $settings_path"
    log "Claude Desktop 3P gateway config written to $desktop_path"
}

write_codex_connection() {
    local base_url=$1
    local config_path="$HOME/.codex/config.toml"
    local state_path="$CONNECT_STATE_DIR/codex.json"
    mkdir -p "$CONNECT_STATE_DIR"
    python3 - "$config_path" "$state_path" "$base_url" <<'PY'
import json
import re
import shutil
import sys
import time
from pathlib import Path

config_path = Path(sys.argv[1])
state_path = Path(sys.argv[2])
base_url = sys.argv[3].rstrip("/")
provider_base = f"{base_url}/v1"
stamp = str(int(time.time()))
begin = "# BEGIN theorem connect codex"
end = "# END theorem connect codex"

def backup(path):
    backup_path = state_path.parent / f"codex-config.{stamp}.bak"
    if path.exists():
        shutil.copy2(path, backup_path)
        existed = True
    else:
        backup_path.write_text("")
        existed = False
    return {"path": str(path), "backup": str(backup_path), "existed": existed}

state = json.loads(state_path.read_text()) if state_path.exists() else {
    "created_at": stamp,
    "files": {"codex_config": backup(config_path)},
}

text = config_path.read_text() if config_path.exists() else ""
managed_re = re.compile(rf"\n?{re.escape(begin)}.*?{re.escape(end)}\n?", re.S)
text = managed_re.sub("\n", text).strip() + "\n"
lines = text.splitlines()
first_table = next((idx for idx, line in enumerate(lines) if line.lstrip().startswith("[")), len(lines))
preamble = lines[:first_table]
rest = lines[first_table:]
replaced = False
for idx, line in enumerate(preamble):
    if re.match(r"\s*model_provider\s*=", line):
        preamble[idx] = 'model_provider = "theorem"'
        replaced = True
        break
if not replaced:
    preamble.append('model_provider = "theorem"')

managed = [
    "",
    begin,
    "[model_providers.theorem]",
    'name = "Theorem local proxy"',
    f'base_url = "{provider_base}"',
    'wire_api = "responses"',
    "requires_openai_auth = false",
    end,
]
out = "\n".join(preamble + rest + managed).strip() + "\n"
config_path.parent.mkdir(parents=True, exist_ok=True)
config_path.write_text(out)
state["base_url"] = base_url
state["provider_base_url"] = provider_base
state_path.write_text(json.dumps(state, indent=2, sort_keys=False) + "\n")
PY
    log "Codex user config written to $config_path"
}

restore_connection() {
    local agent=$1
    local state_path="$CONNECT_STATE_DIR/$agent.json"
    if [[ ! -f "$state_path" ]]; then
        log "no theorem connection state for $agent at $state_path"
        return 1
    fi
    python3 - "$state_path" <<'PY'
import json
import shutil
import sys
from pathlib import Path

state_path = Path(sys.argv[1])
state = json.loads(state_path.read_text())
for info in state.get("files", {}).values():
    path = Path(info["path"])
    backup = Path(info["backup"])
    if info.get("existed"):
        path.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(backup, path)
    elif path.exists():
        path.unlink()
state_path.unlink()
PY
    log "restored $agent config from $state_path"
}

counter_value() {
    local field=$1
    proxy_status_json | json_field "$field"
}

probe_claude_counter() {
    local base_url
    base_url="$(proxy_base_url)"
    curl -fsS -X POST "$base_url/v1/messages" \
        -H 'content-type: application/json' \
        -H 'anthropic-version: 2023-06-01' \
        -H 'x-api-key: theorem-local-check' \
        --data-binary '{"model":"claude-sonnet-4-5","max_tokens":1,"messages":[{"role":"user","content":"theorem proxy check"}]}' \
        >/dev/null 2>&1 || true
}

probe_codex_counter() {
    local base_url
    base_url="$(proxy_base_url)"
    curl -fsS -X POST "$base_url/v1/responses" \
        -H 'content-type: application/json' \
        -H 'authorization: Bearer theorem-local-check' \
        --data-binary '{"model":"gpt-5.5","input":"theorem proxy check","max_output_tokens":1}' \
        >/dev/null 2>&1 || true
}

check_counter_increment() {
    local field=$1
    local probe=$2
    wait_for_http "$(proxy_base_url)/healthz" || {
        log "proxy is not healthy at $(proxy_base_url)"
        return 1
    }
    local before after
    before="$(counter_value "$field")"
    "$probe"
    after="$(counter_value "$field")"
    if [[ -n "$before" && -n "$after" && "$after" -gt "$before" ]]; then
        log "$field incremented: $before -> $after"
        return 0
    fi
    log "$field did not increment: $before -> $after"
    return 1
}

cmd_connect() {
    local agent=${1:-}
    if [[ -z "$agent" ]]; then
        log "connect requires an agent: claude or codex"
        return 1
    fi
    shift
    local check=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check)
                check=true
                ;;
            -h | --help)
                printf 'usage: theorem connect <claude|codex> [--check]\n'
                return 0
                ;;
            *)
                log "unknown connect flag $1"
                return 1
                ;;
        esac
        shift
    done

    case "$agent" in
        claude | claude-code)
            if [[ "$check" == "true" ]]; then
                check_counter_increment anthropic_messages_seen probe_claude_counter
                return
            fi
            ensure_stack_for_connect
            write_claude_connection "$(proxy_base_url)"
            printf 'Claude Code: restart/open a session; ANTHROPIC_BASE_URL is now %s\n' "$(proxy_base_url)"
            printf 'Claude Desktop: use the Claude-3p app/config; the gateway base URL is %s\n' "$(proxy_base_url)"
            ;;
        codex)
            if [[ "$check" == "true" ]]; then
                check_counter_increment openai_responses_seen probe_codex_counter
                return
            fi
            ensure_stack_for_connect
            write_codex_connection "$(proxy_base_url)"
            printf 'Codex CLI/Desktop: restart Codex so ~/.codex/config.toml is reloaded.\n'
            printf 'Provider base URL: %s/v1\n' "$(proxy_base_url)"
            if [[ "${THEOREM_PROXY_OPENAI_UPSTREAM:-https://api.openai.com}" == "https://api.openai.com" && -z "${THEOREM_PROXY_OPENAI_UPSTREAM_API_KEY:-}" ]]; then
                printf 'Codex note: API/local mode still needs THEOREM_PROXY_OPENAI_UPSTREAM_API_KEY, or set THEOREM_PROXY_OPENAI_UPSTREAM to a local OpenAI-compatible host.\n'
            fi
            ;;
        *)
            log "unsupported connect agent $agent"
            return 1
            ;;
    esac
}

cmd_disconnect() {
    local agent=${1:-}
    if [[ -z "$agent" ]]; then
        log "disconnect requires an agent: claude or codex"
        return 1
    fi
    case "$agent" in
        claude | claude-code)
            restore_connection claude
            ;;
        codex)
            restore_connection codex
            ;;
        *)
            log "unsupported disconnect agent $agent"
            return 1
            ;;
    esac
}

ensure_proxy_running() {
    if ! command -v curl >/dev/null 2>&1; then
        log "curl not found"
        return 1
    fi

    local base_url
    base_url="$(legacy_proxy_base_url)"
    if wait_for_proxy "$base_url"; then
        return 0
    fi

    local port="${THEOREM_PROXY_PORT:-8484}"
    local data_dir="${THEOREM_PROXY_DATA_DIR:-$THEOREM_HOME_DIR/proxy}"
    mkdir -p "$THEOREM_HOME_DIR" "$data_dir"
    nohup "$0" proxy --proxy-port "$port" --proxy-data-dir "$data_dir" --proxy-no-ambient \
        >>"$PROXY_OUT_LOG" 2>>"$PROXY_ERR_LOG" &
    local proxy_pid=$!
    printf '%s\n' "$proxy_pid" >"$PROXY_PID_FILE"
    if ! wait_for_proxy "$base_url"; then
        kill "$proxy_pid" 2>/dev/null || true
        log "proxy did not become healthy at $base_url"
        return 1
    fi
    log "started proxy pid $proxy_pid at $base_url"
}

git_value_or_empty() {
    local repo=$1
    shift
    if [[ -n "$repo" ]] && command -v git >/dev/null 2>&1; then
        git -C "$repo" "$@" 2>/dev/null || true
    fi
}

presence_label() {
    case "$1" in
        codex)
            printf 'Codex\n'
            ;;
        claude-code)
            printf 'Claude Code\n'
            ;;
        gemma)
            printf 'Gemma\n'
            ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

announce_presence() {
    local actor=$1
    local endpoint=$2
    local surface=$3
    local summary=$4
    local room_id=$5
    local ttl=$6

    ensure_proxy_running
    local base_url
    base_url="$(legacy_proxy_base_url)"

    local path="${THEOREM_PRESENCE_PATH:-.}"
    local line="${THEOREM_PRESENCE_LINE:-1}"
    local col="${THEOREM_PRESENCE_COL:-0}"
    local label
    label="$(presence_label "$actor")"

    local payload
    payload=$(cat <<EOF
{
  "actor": $(json_quote "$actor"),
  "path": $(json_quote "$path"),
  "line": $line,
  "col": $col,
  "label": $(json_quote "$label"),
  "kind": "agent",
  "ttl_seconds": $ttl
}
EOF
)
    local response
    response="$(curl -fsS -X POST "$base_url/v1/presence" \
        -H 'content-type: application/json' \
        --data-binary "$payload")"

    if [[ "${THEOREM_PROXY_LEGACY_ROOM_SYNC:-0}" != "0" ]]; then
        announce_legacy_room_presence \
            "$actor" \
            "$endpoint" \
            "$surface" \
            "$summary" \
            "$room_id" \
            "$ttl" >/dev/null || log "legacy harness room sync failed for $actor"
    fi

    printf '%s\n' "$response"
}

announce_legacy_room_presence() {
    local actor=$1
    local endpoint=$2
    local surface=$3
    local summary=$4
    local room_id=$5
    local ttl=$6

    local base_url
    base_url="$(legacy_proxy_base_url)"

    local repo=""
    if repo="$(find_repo 2>/dev/null)"; then
        :
    else
        repo=""
    fi
    local worktree="$repo"
    local branch
    branch="$(git_value_or_empty "$repo" rev-parse --abbrev-ref HEAD)"
    local head
    head="$(git_value_or_empty "$repo" rev-parse --short HEAD)"
    local repo_name
    repo_name="$(git_value_or_empty "$repo" config --get remote.origin.url)"
    if [[ -z "$repo_name" ]]; then
        repo_name="Theorem"
    fi

    local payload
    payload=$(cat <<EOF
{
  "actor_id": $(json_quote "$actor"),
  "room_id": $(json_quote "$room_id"),
  "surface": $(json_quote "$surface"),
  "status": "active",
  "worktree": $(json_quote "$worktree"),
  "branch": $(json_quote "$branch"),
  "head": $(json_quote "$head"),
  "repo": $(json_quote "$repo_name"),
  "task": $(json_quote "local proxy presence"),
  "endpoint": $(json_quote "$endpoint"),
  "summary": $(json_quote "$summary"),
  "capabilities": ["codex.app-server", "codex.exec", "workspace-edit"],
  "ttl_seconds": $ttl
}
EOF
)
    curl -fsS -X POST "$base_url/v1/agents/presence" \
        -H 'content-type: application/json' \
        --data-binary "$payload"
}

presence_heartbeat_loop() {
    local watched_pid=$1
    local actor=$2
    local endpoint=$3
    local surface=$4
    local summary=$5
    local room_id=$6
    local ttl=$7
    local interval=$8

    while kill -0 "$watched_pid" 2>/dev/null; do
        sleep "$interval" || return 0
        if ! kill -0 "$watched_pid" 2>/dev/null; then
            return 0
        fi
        if ! announce_presence "$actor" "$endpoint" "$surface" "$summary" "$room_id" "$ttl" >/dev/null; then
            log "presence heartbeat failed for $actor"
        fi
    done
}

presence_heartbeat_forever() {
    local actor=$1
    local endpoint=$2
    local surface=$3
    local summary=$4
    local room_id=$5
    local ttl=$6
    local interval=$7

    while true; do
        sleep "$interval" || return 0
        if ! announce_presence "$actor" "$endpoint" "$surface" "$summary" "$room_id" "$ttl" >/dev/null; then
            log "presence heartbeat failed for $actor"
        fi
    done
}

cmd_appear() {
    local actor=codex
    if [[ $# -gt 0 && "$1" != -* ]]; then
        actor=$1
        shift
    fi
    local room_id="${THEOREM_PROXY_ROOM_ID:-repo:theorem:branch:main}"
    local endpoint="${THEOREM_CODEX_APP_ENDPOINT:-}"
    local surface="theorem-proxy"
    local summary=""
    local ttl="${THEOREM_PROXY_PRESENCE_TTL:-120}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --room | --room-id)
                shift
                room_id=${1:?--room requires a room id}
                ;;
            --endpoint)
                shift
                endpoint=${1:?--endpoint requires a URL}
                ;;
            --surface)
                shift
                surface=${1:?--surface requires a value}
                ;;
            --summary)
                shift
                summary=${1:?--summary requires text}
                ;;
            --ttl)
                shift
                ttl=${1:?--ttl requires seconds}
                ;;
            -h | --help)
                printf 'usage: theorem appear [actor] [--room id] [--endpoint url] [--surface name] [--summary text] [--ttl seconds]\n'
                return 0
                ;;
            *)
                log "unknown appear flag $1"
                return 1
                ;;
        esac
        shift
    done

    if [[ -z "$summary" ]]; then
        if [[ -n "$endpoint" ]]; then
            summary="$actor local endpoint ready at $endpoint"
        else
            summary="$actor is active through the local Theorem proxy"
        fi
    fi
    announce_presence "$actor" "$endpoint" "$surface" "$summary" "$room_id" "$ttl"
}

cmd_codex_endpoint() {
    if ! command -v codex >/dev/null 2>&1; then
        log "codex not found on PATH"
        return 1
    fi
    local port="${THEOREM_CODEX_APP_PORT:-18489}"
    local endpoint="${THEOREM_CODEX_APP_ENDPOINT:-ws://127.0.0.1:$port}"
    local room_id="${THEOREM_PROXY_ROOM_ID:-repo:theorem:branch:main}"
    local ttl="${THEOREM_PROXY_PRESENCE_TTL:-120}"
    local heartbeat_interval="${THEOREM_PROXY_HEARTBEAT_INTERVAL:-45}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)
                shift
                port=${1:?--port requires a port}
                endpoint="ws://127.0.0.1:$port"
                ;;
            --listen | --endpoint)
                shift
                endpoint=${1:?--listen requires a URL}
                ;;
            --room | --room-id)
                shift
                room_id=${1:?--room requires a room id}
                ;;
            --ttl)
                shift
                ttl=${1:?--ttl requires seconds}
                ;;
            --heartbeat | --heartbeat-interval)
                shift
                heartbeat_interval=${1:?--heartbeat requires seconds}
                ;;
            --)
                shift
                break
                ;;
            -h | --help)
                printf 'usage: theorem codex-endpoint [--port port | --listen ws://ip:port] [--room id] [--ttl seconds] [--heartbeat seconds] [-- codex app-server args]\n'
                return 0
                ;;
            *)
                break
                ;;
        esac
        shift
    done

    codex app-server --listen "$endpoint" "$@" &
    local codex_pid=$!
    sleep 0.2
    if ! kill -0 "$codex_pid" 2>/dev/null; then
        wait "$codex_pid"
        return $?
    fi
    announce_presence \
        codex \
        "$endpoint" \
        "codex:app-server" \
        "Codex app-server endpoint ready at $endpoint" \
        "$room_id" \
        "$ttl"
    presence_heartbeat_loop \
        "$codex_pid" \
        codex \
        "$endpoint" \
        "codex:app-server" \
        "Codex app-server endpoint live at $endpoint" \
        "$room_id" \
        "$ttl" \
        "$heartbeat_interval" &
    local heartbeat_pid=$!
    trap 'kill "$heartbeat_pid" 2>/dev/null || true; kill "$codex_pid" 2>/dev/null || true' EXIT INT TERM
    local status=0
    wait "$codex_pid" || status=$?
    kill "$heartbeat_pid" 2>/dev/null || true
    trap - EXIT INT TERM
    return "$status"
}

announce_wrapped_codex() {
    local codex_pid=$1
    local base_url=$2
    local room_id="${THEOREM_PROXY_ROOM_ID:-repo:theorem:branch:main}"
    local ttl="${THEOREM_PROXY_PRESENCE_TTL:-120}"
    local heartbeat_interval="${THEOREM_PROXY_HEARTBEAT_INTERVAL:-45}"
    announce_presence \
        codex \
        "$base_url" \
        "codex:cli" \
        "Codex CLI active through local Theorem proxy" \
        "$room_id" \
        "$ttl" >/dev/null
    presence_heartbeat_loop \
        "$codex_pid" \
        codex \
        "$base_url" \
        "codex:cli" \
        "Codex CLI active through local Theorem proxy" \
        "$room_id" \
        "$ttl" \
        "$heartbeat_interval"
}

announce_wrapped_claude_loop() {
    local base_url=$1
    local room_id="${THEOREM_PROXY_ROOM_ID:-repo:theorem:branch:main}"
    local ttl="${THEOREM_PROXY_PRESENCE_TTL:-120}"
    local heartbeat_interval="${THEOREM_PROXY_HEARTBEAT_INTERVAL:-45}"
    announce_presence \
        claude-code \
        "$base_url" \
        "claude-code:cli" \
        "Claude Code active through local Theorem proxy" \
        "$room_id" \
        "$ttl" >/dev/null
    presence_heartbeat_forever \
        claude-code \
        "$base_url" \
        "claude-code:cli" \
        "Claude Code active through local Theorem proxy" \
        "$room_id" \
        "$ttl" \
        "$heartbeat_interval"
}

cmd_wrap() {
    local target=${1:-}
    if [[ -z "$target" ]]; then
        log "wrap requires a command, for example: theorem wrap claude"
        return 1
    fi
    shift
    if [[ "$target" != "claude" && "$target" != "claude-code" && "$target" != "codex" ]]; then
        log "unsupported wrap target $target"
        return 1
    fi

    local port="${THEOREM_PROXY_PORT:-8484}"
    local data_dir="${THEOREM_PROXY_DATA_DIR:-$THEOREM_HOME_DIR/proxy}"
    local base_url="http://127.0.0.1:$port"
    mkdir -p "$data_dir"

    "$0" proxy --proxy-port "$port" --proxy-data-dir "$data_dir" &
    local proxy_pid=$!
    trap 'kill "$proxy_pid" 2>/dev/null || true' EXIT INT TERM
    if ! wait_for_proxy "$base_url"; then
        log "proxy did not become healthy at $base_url"
        return 1
    fi
    if [[ "$target" == "codex" ]]; then
        if ! command -v codex >/dev/null 2>&1; then
            log "codex not found on PATH"
            return 1
        fi
        THEOREM_ROOM_PROXY_URL="$base_url" codex "$@" &
        local codex_pid=$!
        announce_wrapped_codex "$codex_pid" "$base_url" &
        local heartbeat_pid=$!
        trap 'kill "$heartbeat_pid" 2>/dev/null || true; kill "$codex_pid" 2>/dev/null || true; kill "$proxy_pid" 2>/dev/null || true' EXIT INT TERM
        local status=0
        wait "$codex_pid" || status=$?
        kill "$heartbeat_pid" 2>/dev/null || true
        return "$status"
    fi
    if ! command -v claude >/dev/null 2>&1; then
        log "claude not found on PATH"
        return 1
    fi
    announce_wrapped_claude_loop "$base_url" &
    local heartbeat_pid=$!
    trap 'kill "$heartbeat_pid" 2>/dev/null || true; kill "$proxy_pid" 2>/dev/null || true' EXIT INT TERM
    local status=0
    ANTHROPIC_BASE_URL="$base_url" ENABLE_TOOL_SEARCH=true claude "$@" || status=$?
    kill "$heartbeat_pid" 2>/dev/null || true
    trap - EXIT INT TERM
    return "$status"
}

cmd_stop() {
    if [[ -f "$NODE_PID_FILE" ]]; then
        local node_pid
        node_pid="$(cat "$NODE_PID_FILE")"
        if kill -0 "$node_pid" 2>/dev/null; then
            kill "$node_pid"
            log "stopped node pid $node_pid"
        else
            log "node pid $node_pid is not running"
        fi
        rm -f "$NODE_PID_FILE"
    fi
    if [[ ! -f "$PID_FILE" ]]; then
        log "no pid file at $PID_FILE"
    else
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid"
            log "stopped localmodel pid $pid"
        else
            log "localmodel pid $pid is not running"
        fi
        rm -f "$PID_FILE"
    fi
    if [[ -f "$PROXY_PID_FILE" ]]; then
        local proxy_pid
        proxy_pid="$(cat "$PROXY_PID_FILE")"
        if kill -0 "$proxy_pid" 2>/dev/null; then
            kill "$proxy_pid"
            log "stopped proxy pid $proxy_pid"
        else
            log "proxy pid $proxy_pid is not running"
        fi
        rm -f "$PROXY_PID_FILE"
    fi
}

cmd_status() {
    local repo=""
    if repo="$(find_repo 2>/dev/null)"; then
        printf 'source: %s\n' "$repo"
    else
        printf 'source: unavailable (binary install)\n'
    fi
    if find_agentd_bin >/dev/null; then
        printf 'localmodel binary: %s\n' "$(find_agentd_bin)"
    else
        printf 'localmodel binary: cargo fallback\n'
    fi
    if find_proxy_bin >/dev/null; then
        printf 'proxy binary: %s\n' "$(find_proxy_bin)"
    else
        printf 'proxy binary: cargo/rustyred-proxy fallback\n'
    fi
    if find_theorem_proxy_bin >/dev/null; then
        printf 'theorem-proxy binary: %s\n' "$(find_theorem_proxy_bin)"
    else
        printf 'theorem-proxy binary: not found\n'
    fi
    if find_federation_bin >/dev/null; then
        printf 'theorem-federation binary: %s\n' "$(find_federation_bin)"
    else
        printf 'theorem-federation binary: cargo fallback\n'
    fi
    if http_ok "$(node_base_url)/ready"; then
        printf 'node: ready (%s)\n' "$(node_base_url)"
    elif [[ -f "$NODE_PID_FILE" ]]; then
        local node_pid
        node_pid="$(cat "$NODE_PID_FILE")"
        if kill -0 "$node_pid" 2>/dev/null; then
            printf 'node: starting or unhealthy (pid %s, %s)\n' "$node_pid" "$(node_base_url)"
        else
            printf 'node: stale pid file (%s)\n' "$node_pid"
        fi
    else
        printf 'node: not running (%s)\n' "$(node_base_url)"
    fi
    if [[ "${THEOREM_PROXY_OPENAI_UPSTREAM:-https://api.openai.com}" == "https://api.openai.com" && -z "${THEOREM_PROXY_OPENAI_UPSTREAM_API_KEY:-}" ]]; then
        printf 'codex upstream: missing THEOREM_PROXY_OPENAI_UPSTREAM_API_KEY for api.openai.com\n'
    else
        printf 'codex upstream: configured (%s)\n' "${THEOREM_PROXY_OPENAI_UPSTREAM:-https://api.openai.com}"
    fi
    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            printf 'localmodel: running (pid %s)\n' "$pid"
        else
            printf 'localmodel: stale pid file (%s)\n' "$pid"
        fi
    else
        printf 'localmodel: not started by install.sh\n'
    fi
    if [[ -f "$PROXY_PID_FILE" ]]; then
        local proxy_pid
        proxy_pid="$(cat "$PROXY_PID_FILE")"
        if kill -0 "$proxy_pid" 2>/dev/null; then
            printf 'proxy: running (pid %s, %s)\n' "$proxy_pid" "$(proxy_base_url)"
        else
            if http_ok "$(proxy_base_url)/healthz"; then
                rm -f "$PROXY_PID_FILE"
                printf 'proxy: running (%s; removed stale pid file %s)\n' "$(proxy_base_url)" "$proxy_pid"
            else
                printf 'proxy: stale pid file (%s)\n' "$proxy_pid"
                printf 'proxy: not running (%s)\n' "$(proxy_base_url)"
            fi
        fi
    elif http_ok "$(proxy_base_url)/healthz"; then
        printf 'proxy: running (%s)\n' "$(proxy_base_url)"
    else
        printf 'proxy: not started by theorem wrapper\n'
    fi
    if http_ok "$(proxy_base_url)/healthz"; then
        local status_tmp
        status_tmp="$(mktemp -t theorem-proxy-status.XXXXXX)"
        if proxy_status_json >"$status_tmp" 2>/dev/null; then
            python3 - "$status_tmp" <<'PY'
import json
import sys
from pathlib import Path

data = json.loads(Path(sys.argv[1]).read_text())
print(
    "proxy counters: "
    f"anthropic_messages={data.get('anthropic_messages_seen', 0)} "
    f"openai_responses={data.get('openai_responses_seen', 0)} "
    f"total={data.get('total_requests_seen', 0)}"
)
PY
            rm -f "$status_tmp"
        fi
    fi
}

cmd_logs() {
    mkdir -p "$THEOREM_HOME_DIR"
    touch "$OUT_LOG" "$ERR_LOG" "$PROXY_OUT_LOG" "$PROXY_ERR_LOG"
    tail -f "$OUT_LOG" "$ERR_LOG" "$PROXY_OUT_LOG" "$PROXY_ERR_LOG"
}

cmd_doctor() {
    local ok=true
    if find_agentd_bin >/dev/null; then
        log "localmodel binary: $(find_agentd_bin)"
        if command -v git >/dev/null 2>&1; then
            log "git found"
        fi
    else
        if ! command -v cargo >/dev/null 2>&1; then
            log "cargo not found and no theorem-localmodel binary found"
            ok=false
        fi
        if ! command -v git >/dev/null 2>&1; then
            log "git not found"
            ok=false
        fi
        if find_repo >/dev/null; then
            log "source checkout: $(find_repo)"
        else
            ok=false
        fi
    fi
    if [[ "$ok" == "true" ]]; then
        log "wrapper prerequisites passed"
    fi

    local proxy_bin
    if proxy_bin="$(find_theorem_proxy_bin 2>/dev/null)"; then
        "$proxy_bin" doctor \
            --memory-url "$(node_base_url)/mcp" \
            --proxy-url "$(proxy_base_url)" || ok=false
    else
        log "theorem-proxy binary not found"
        ok=false
    fi

    case "${THEOREM_FEDERATION_ENABLED:-}" in
        1 | true | TRUE | yes | YES | on | ON)
            cmd_federation doctor --bind-endpoint || ok=false
            ;;
        *)
            cmd_federation doctor >/dev/null || log "federation doctor skipped; build apps/theorem-federation for full status"
            ;;
    esac

    if [[ "$ok" == "true" ]]; then
        log "doctor passed"
        return 0
    fi
    return 1
}

main() {
    local command=${1:-help}
    if [[ $# -gt 0 ]]; then
        shift
    fi

    case "$command" in
        init)
            cmd_init "$@"
            ;;
        harness)
            cmd_harness "$@"
            ;;
        start)
            cmd_start "$@"
            ;;
        serve-model)
            cmd_serve_model "$@"
            ;;
        up)
            cmd_up "$@"
            ;;
        proxy)
            cmd_proxy "$@"
            ;;
        graph)
            cmd_graph "$@"
            ;;
        federation)
            cmd_federation "$@"
            ;;
        connect)
            cmd_connect "$@"
            ;;
        disconnect)
            cmd_disconnect "$@"
            ;;
        appear)
            cmd_appear "$@"
            ;;
        codex-endpoint)
            cmd_codex_endpoint "$@"
            ;;
        wrap)
            cmd_wrap "$@"
            ;;
        once)
            cmd_once "$@"
            ;;
        stop)
            cmd_stop
            ;;
        status)
            cmd_status
            ;;
        logs)
            cmd_logs
            ;;
        doctor)
            cmd_doctor
            ;;
        model-doctor)
            cmd_model_doctor "$@"
            ;;
        localmodel)
            run_agentd "$@"
            ;;
        agentd)
            run_agentd "$@"
            ;;
        repo)
            find_repo
            ;;
        help | -h | --help)
            usage
            ;;
        *)
            log "unknown command $command"
            usage >&2
            return 1
            ;;
    esac
}

main "$@"
