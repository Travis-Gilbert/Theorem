class Rustyred < Formula
  desc "Local Theorem/RustyRed proxy for Claude Code and Anthropic Messages clients"
  homepage "https://github.com/Travis-Gilbert/Theorem"
  version "__VERSION__"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/Travis-Gilbert/Theorem/releases/download/__TAG__/rustyred-aarch64-apple-darwin.tar.gz"
      sha256 "__SHA_AARCH64_APPLE_DARWIN__"
    else
      url "https://github.com/Travis-Gilbert/Theorem/releases/download/__TAG__/rustyred-x86_64-apple-darwin.tar.gz"
      sha256 "__SHA_X86_64_APPLE_DARWIN__"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/Travis-Gilbert/Theorem/releases/download/__TAG__/rustyred-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_AARCH64_UNKNOWN_LINUX_GNU__"
    else
      url "https://github.com/Travis-Gilbert/Theorem/releases/download/__TAG__/rustyred-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_X86_64_UNKNOWN_LINUX_GNU__"
    end
  end

  def install
    bin.install "theorem-agentd"
    bin.install "theorem-localmodel"
    bin.install "rustyred-proxy"
    bin.install "theorem"
    bin.install "rustyred"
  end

  test do
    system "#{bin}/rustyred", "doctor"
  end
end
