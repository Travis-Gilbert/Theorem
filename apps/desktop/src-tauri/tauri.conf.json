{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CommonPlace",
  "version": "0.1.0",
  "identifier": "com.theorem.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../../../travisgilbert.me run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm --prefix ../../../travisgilbert.me run build:desktop",
    "frontendDist": "../../../../travisgilbert.me/out"
  },
  "app": {
    "windows": [
      {
        "title": "CommonPlace",
        "width": 1280,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
