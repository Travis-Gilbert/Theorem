# Velt API key (client-side, domain-gated). Safelist your dev domain
# (localhost:5173) under "Managed Domains" in the Velt console.
VITE_VELT_API_KEY=YOUR_VELT_API_KEY

# Shared document id — every peer on the same id converges on the same doc.
VITE_DOC_ID=copresence-demo-doc-1

# Phase 2 (Ask Gemma): any OpenAI-compatible chat endpoint serving Gemma 12B.
# agentd's model loop, Ollama (http://localhost:11434/v1), or a hosted endpoint.
VITE_GEMMA_BASE_URL=http://localhost:11434/v1
VITE_GEMMA_MODEL=gemma2:9b
# Optional bearer token for the Gemma endpoint (leave blank for local).
VITE_GEMMA_API_KEY=
