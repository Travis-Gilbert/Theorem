# Harness Console environment.
# The console consumes the harness backend; it rebuilds nothing.

# The single MCP/HTTP endpoint coding agents and this console call.
NEXT_PUBLIC_HARNESS_URL="https://rustyredcore-theorem-production.up.railway.app"
NEXT_PUBLIC_HARNESS_MCP_PATH="/mcp"

# Data source for the console. "mock" renders every surface from local fixtures
# (the default for local dev and the greenfield build); "live" routes the typed
# client to the real harness over MCP/HTTP.
NEXT_PUBLIC_HARNESS_SOURCE="mock"

# Tenant baked into issued harness keys is resolved server side; the console
# never sends a tenant. This is only the display default for the tenant selector.
NEXT_PUBLIC_DEFAULT_TENANT="rustyredcore-theorem-production"

# RustyWeb search toggle target for the Dynamic Island search lane. Optional;
# falls back to graph search over the harness when unset.
NEXT_PUBLIC_RUSTYWEB_ENABLED="true"
