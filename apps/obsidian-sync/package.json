{
  "name": "theorem-harness-sync",
  "version": "0.1.0",
  "description": "Obsidian plugin that mirrors a Theorem harness memory graph into a vault and writes note edits back into the graph.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "test": "node test/build.mjs && node --test test/bundled/*.test.js"
  },
  "keywords": [
    "obsidian",
    "theorem",
    "harness",
    "knowledge-graph"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.11",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0"
  }
}
