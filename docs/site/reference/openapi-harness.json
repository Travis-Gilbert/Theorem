{
  "components": {
    "parameters": {
      "IntentId": {
        "in": "path",
        "name": "intent_id",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "MapId": {
        "in": "path",
        "name": "map_id",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "RoomId": {
        "description": "e.g. repo:theorem:branch:main.",
        "in": "path",
        "name": "room_id",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "RunId": {
        "in": "path",
        "name": "run_id",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "Tenant": {
        "description": "Tenant slug. Alias `tenant_slug` is also accepted. Required unless the server has a non-default tenant env configured.",
        "in": "query",
        "name": "tenant",
        "required": false,
        "schema": {
          "example": "Travis-Gilbert",
          "type": "string"
        }
      }
    },
    "schemas": {
      "CompoundActionItem": {
        "additionalProperties": true,
        "description": "A suggested follow-up derived from Compound Engineering receipts. It is never executed by this read route.",
        "properties": {
          "action_id": {
            "type": "string"
          },
          "action_type": {
            "examples": [
              "open_fix_task",
              "review_promotion_proposal"
            ],
            "type": "string"
          },
          "cluster_key": {
            "type": "string"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object"
          },
          "severity": {
            "examples": [
              "medium",
              "high"
            ],
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "supporting_capture_doc_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "supporting_record_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "CompoundEngineeringSummary": {
        "additionalProperties": true,
        "description": "Read-only Compound Engineering summary: background captures, gate records, and reviewable action candidates.",
        "properties": {
          "action_count": {
            "type": "integer"
          },
          "action_items": {
            "items": {
              "$ref": "#/components/schemas/CompoundActionItem"
            },
            "type": "array"
          },
          "capture_count": {
            "type": "integer"
          },
          "captures": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          },
          "config_hash": {
            "type": "string"
          },
          "record_count": {
            "type": "integer"
          },
          "records": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          },
          "run_counter": {
            "type": "integer"
          },
          "tenant_slug": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ConnectionTarget": {
        "additionalProperties": true,
        "description": "How to reach an MCP server. The stdio transport is shown.",
        "properties": {
          "args": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "command": {
            "type": "string"
          },
          "env": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "type": {
            "enum": [
              "stdio"
            ],
            "type": "string"
          }
        },
        "required": [
          "type"
        ],
        "type": "object"
      },
      "Event": {
        "additionalProperties": true,
        "description": "One transition in a run's append-ordered event log.",
        "properties": {
          "state_hash_after": {
            "type": "string"
          },
          "type": {
            "description": "e.g. RUN.CREATED, HOST.OBSERVED",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Job": {
        "additionalProperties": true,
        "description": "The persisted job thread.",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "priority": {
            "enum": [
              "P0",
              "P1",
              "P2"
            ],
            "type": "string"
          },
          "repo": {
            "type": "string"
          },
          "target_head": {
            "enum": [
              "claude",
              "codex",
              "either"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "JobSubmission": {
        "additionalProperties": true,
        "description": "Core dispatch job fields (flattened into JobSubmitBody).",
        "properties": {
          "idempotency_key": {
            "type": "string"
          },
          "job_id": {
            "description": "Omit to auto-mint a job- ULID.",
            "type": "string"
          },
          "not_before": {
            "format": "date-time",
            "type": "string"
          },
          "priority": {
            "default": "P2",
            "enum": [
              "P0",
              "P1",
              "P2"
            ],
            "type": "string"
          },
          "repo": {
            "type": "string"
          },
          "source_project_id": {
            "type": "string"
          },
          "source_task_id": {
            "type": "string"
          },
          "spec_inline": {
            "type": "string"
          },
          "spec_ref": {
            "type": "string"
          },
          "target_head": {
            "default": "either",
            "enum": [
              "claude",
              "codex",
              "either"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "repo"
        ],
        "type": "object"
      },
      "JobSubmitBody": {
        "allOf": [
          {
            "properties": {
              "room_id": {
                "type": "string"
              },
              "submitted_by": {
                "type": "string"
              },
              "tenant": {
                "type": "string"
              },
              "tenant_slug": {
                "type": "string"
              }
            },
            "type": "object"
          },
          {
            "$ref": "#/components/schemas/JobSubmission"
          }
        ]
      },
      "MapArtifact": {
        "additionalProperties": true,
        "description": "A codebase map projected into the graph.",
        "properties": {
          "entries": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          },
          "entry_count": {
            "type": "integer"
          },
          "map_id": {
            "type": "string"
          },
          "map_kind": {
            "example": "CodebaseMap",
            "type": "string"
          },
          "markdown_body": {
            "type": "string"
          },
          "repo_id": {
            "type": "string"
          },
          "scope_kind": {
            "example": "repo",
            "type": "string"
          },
          "scope_ref": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "MessagePost": {
        "properties": {
          "actor_id": {
            "type": "string"
          },
          "delivery": {
            "default": "passive",
            "enum": [
              "passive",
              "wake"
            ],
            "type": "string"
          },
          "mentions": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "message": {
            "type": "string"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object"
          },
          "tenant_slug": {
            "example": "Travis-Gilbert",
            "type": "string"
          },
          "urgency": {
            "description": "Coordination urgency.",
            "enum": [
              "info",
              "ask",
              "block"
            ],
            "type": "string"
          }
        },
        "required": [
          "actor_id",
          "message"
        ],
        "type": "object"
      },
      "RegisterConnectorBody": {
        "properties": {
          "label": {
            "description": "Defaults to server_id if empty.",
            "type": "string"
          },
          "server_id": {
            "type": "string"
          },
          "target": {
            "$ref": "#/components/schemas/ConnectionTarget"
          },
          "tenant": {
            "example": "Travis-Gilbert",
            "type": "string"
          }
        },
        "required": [
          "server_id",
          "target"
        ],
        "type": "object"
      },
      "RegisterContentCoreConnectorBody": {
        "properties": {
          "label": {
            "description": "Defaults to Content Core.",
            "type": "string"
          },
          "tenant": {
            "example": "Travis-Gilbert",
            "type": "string"
          },
          "tenant_slug": {
            "example": "Travis-Gilbert",
            "type": "string"
          }
        },
        "type": "object"
      },
      "RoomMessageEvent": {
        "additionalProperties": true,
        "description": "A coordination room message event (also the SSE payload).",
        "properties": {
          "author": {
            "type": "string"
          },
          "delivery": {
            "enum": [
              "Passive",
              "Wake"
            ],
            "type": "string"
          },
          "mentions": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "message": {
            "type": "string"
          },
          "message_id": {
            "type": "string"
          },
          "room_id": {
            "type": "string"
          },
          "tenant_slug": {
            "type": "string"
          },
          "urgency": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Run": {
        "additionalProperties": true,
        "description": "Serialized harness run state. Core fields shown; additional fields may be present.",
        "properties": {
          "actor": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "state_hash": {
            "type": "string"
          },
          "task": {
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "description": "The HTTP surface of `theorem-harness-server`: a thin Axum server over a durable file-backed graph store. It serves the read contract Theorem clients consume (runs, codebase maps, coordination rooms, presence, intents, records, mentions, and Compound Engineering captures/action candidates) plus write endpoints for room messages, dispatch jobs, and MCP connector registration.\n\nScope: this is the Harness product transport only. The graph engine (`rustyred-thg-server`) is a separate service with its own, larger API published at its own `GET /openapi.json`.\n\nAuthentication: this server performs NO authentication today. The tenant is supplied as a plain `tenant` (or `tenant_slug`) string per request, or by a non-default configured value from `THEOREM_HARNESS_TENANT_SLUG`, `THEOREM_AGENT_TENANT_SLUG`, or `THEOREM_TENANT_ID`; silent fallback to `default` is refused. Write endpoints (`POST /harness/jobs`, `POST /connectors/register`, `POST /harness/rooms/{room_id}/messages`) are therefore unauthenticated. Run it on a trusted network or behind an authenticating proxy before exposing it publicly.\n\nResponse shapes: envelope keys are stable and documented here. Inner objects (a run, an event, a room, an intent) are serialized graph-node state; their fields are described where pinned and otherwise left open rather than guessed.",
    "summary": "HTTP/JSON transport for Theorem's Harness — runs, rooms, compound learning, jobs, and connectors.",
    "title": "Theorem Harness HTTP API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/connectors": {
      "get": {
        "description": "Read-only and fast; contacts no external server.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Tenant"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "affordances": {
                      "items": {
                        "additionalProperties": true,
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "connectors": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    "count": {
                      "type": "integer"
                    },
                    "tenant": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Registered connectors and the affordances learned from them."
          }
        },
        "summary": "List registered MCP connectors and their tool affordances",
        "tags": [
          "connectors"
        ]
      }
    },
    "/connectors/register": {
      "post": {
        "description": "Spawns the target MCP server, performs the initialize -> notifications/initialized -> tools/list handshake, and registers each tool as a learnable affordance node under (tenant, server_id). The connection target is persisted so a selected tool can be invoked later.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterConnectorBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "affordance_ids": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    "count": {
                      "type": "integer"
                    },
                    "server": {
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "protocol": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "server_id": {
                      "type": "string"
                    },
                    "tenant": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "The server info and the registered affordance ids."
          },
          "400": {
            "description": "Missing server_id."
          },
          "502": {
            "description": "MCP server handshake failed."
          }
        },
        "summary": "Connect to an MCP server and register its tools as affordances",
        "tags": [
          "connectors"
        ]
      }
    },
    "/connectors/register/content-core": {
      "post": {
        "description": "Uses the configured content-core stdio target (default `uvx content-core mcp`) and persists it as the `content-core` connector. The registered tools surface in the content_extraction affordance family.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterContentCoreConnectorBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "affordance_ids": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    "count": {
                      "type": "integer"
                    },
                    "server": {
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "protocol": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "server_id": {
                      "example": "content-core",
                      "type": "string"
                    },
                    "tenant": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "The content-core server info and registered affordance ids."
          },
          "400": {
            "description": "Missing tenant."
          },
          "502": {
            "description": "content-core MCP handshake failed."
          }
        },
        "summary": "Register the content-core MCP server",
        "tags": [
          "connectors"
        ]
      }
    },
    "/github/webhook": {
      "post": {
        "description": "Only mounted when GitHub App env config is present. Verifies the X-Hub-Signature-256 HMAC, deduplicates by X-GitHub-Delivery, and ingests push/PR/issue/review events into the code graph. Also available at /github/webhooks. Omitted entirely when GitHub App config is unset.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted (possibly a duplicate delivery)."
          },
          "400": {
            "description": "Missing signature, event, or delivery header."
          },
          "401": {
            "description": "Invalid signature."
          }
        },
        "summary": "GitHub App webhook (conditionally mounted)",
        "tags": [
          "operations"
        ]
      }
    },
    "/harness/actors/{actor_id}/mentions": {
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "actor_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Tenant"
          },
          {
            "description": "Single urgency filter (info, ask, block). Alias of `urgencies`.",
            "in": "query",
            "name": "urgency",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Comma-separated urgency filter.",
            "in": "query",
            "name": "urgencies",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "If true, mark the returned mentions as read.",
            "in": "query",
            "name": "consume",
            "required": false,
            "schema": {
              "default": false,
              "type": "boolean"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 20,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "actor_id": {
                      "type": "string"
                    },
                    "consumed": {
                      "type": "boolean"
                    },
                    "count": {
                      "type": "integer"
                    },
                    "mentions": {
                      "items": {
                        "additionalProperties": true,
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "tenant": {
                      "type": "string"
                    },
                    "urgencies": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Pending mentions for the actor."
          }
        },
        "summary": "Read (and optionally consume) an actor's mention inbox",
        "tags": [
          "actors"
        ]
      }
    },
    "/harness/compound-engineering": {
      "get": {
        "description": "Returns the passive run-close learning surface as an agent-visible summary. It does not auto-spawn jobs; repeated failures, promotion proposals, demotions, and tensions are surfaced as reviewable action items.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Tenant"
          },
          {
            "description": "Optional exact cluster key filter.",
            "in": "query",
            "name": "cluster_key",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Optional updated_at lower bound for captures.",
            "in": "query",
            "name": "since",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "compound_engineering": {
                      "$ref": "#/components/schemas/CompoundEngineeringSummary"
                    },
                    "tenant": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Compound Engineering summary for the tenant."
          }
        },
        "summary": "Read Compound Engineering captures, records, and action candidates",
        "tags": [
          "compound"
        ]
      }
    },
    "/harness/gepa/trainsets/{intent_id}": {
      "get": {
        "description": "Returns captured harness runs for the intent as GEPA TrainExample records. The response is generated from persisted run/event state and is empty when no matching runs are present.",
        "parameters": [
          {
            "$ref": "#/components/parameters/IntentId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "examples": {
                      "items": {
                        "additionalProperties": true,
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "intent_id": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "intent_id",
                    "count",
                    "examples"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "GEPA trainset examples for the intent."
          },
          "400": {
            "description": "The matching run data could not be exported as a trainset."
          },
          "500": {
            "description": "The underlying graph store failed."
          }
        },
        "summary": "Export a GEPA trainset for one intent",
        "tags": [
          "gepa"
        ]
      }
    },
    "/harness/jobs": {
      "post": {
        "description": "Creates or upserts a pending Job. The tenant must be supplied as `tenant`/`tenant_slug` unless the server has a non-default tenant env configured. Defaults: room -> repo:theorem:branch:main, submitted_by -> theorem-harness-server. If THEOREM_DISPATCH_DATABASE_URL is set, the job is mirrored into the Postgres dispatch queue and a wake event is emitted to the target head.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobSubmitBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "created": {
                      "type": "boolean"
                    },
                    "dispatch_mirrored": {
                      "type": "boolean"
                    },
                    "job": {
                      "$ref": "#/components/schemas/Job"
                    },
                    "job_id": {
                      "type": "string"
                    },
                    "room_id": {
                      "type": "string"
                    },
                    "tenant": {
                      "type": "string"
                    },
                    "wake_event": {
                      "$ref": "#/components/schemas/RoomMessageEvent"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "The created/updated job and the emitted wake event."
          },
          "400": {
            "description": "Invalid submission."
          },
          "502": {
            "description": "Dispatch queue (Postgres) unavailable."
          }
        },
        "summary": "Submit a dispatch job",
        "tags": [
          "jobs"
        ]
      }
    },
    "/harness/jobs/counts": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "counts": {
                      "items": {
                        "properties": {
                          "count": {
                            "type": "integer"
                          },
                          "state": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "dispatch_configured": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
